<%- include('../partials/layout_start') %>

<div class="page-header">
  <div class="page-header-left">
    <h1>Edit Dataset</h1>
    <div class="page-breadcrumb">
      <a href="/dashboard">Dashboard</a> › <a href="/datasets">Datasets</a> › <a href="/datasets/<%= dataset._id %>"><%= dataset.title.substring(0, 30) %>…</a> › Edit
    </div>
  </div>
  <a href="/datasets/<%= dataset._id %>" class="btn btn-outline">← Cancel</a>
</div>

<div style="max-width: 860px;">
  <form action="/datasets/<%= dataset._id %>?_method=PUT" method="POST" enctype="multipart/form-data" data-loading>

    <div class="card" style="margin-bottom: 20px;">
      <div class="card-body">
        <div class="form-section-title">📄 Paper Information</div>

        <div class="form-group">
          <label class="form-label required" for="title">Title</label>
          <input type="text" id="title" name="title" class="form-control"
            value="<%= dataset.title %>" required maxlength="200">
        </div>

        <div class="form-group">
          <label class="form-label required" for="authors">Authors</label>
          <input type="text" id="authors" name="authors" class="form-control"
            value="<%= dataset.authors %>" required>
        </div>

        <div class="form-group">
          <label class="form-label required" for="abstract">Abstract</label>
          <textarea id="abstract" name="abstract" class="form-control" rows="5" required><%= dataset.abstract %></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label required" for="publicationYear">Publication Year</label>
            <input type="number" id="publicationYear" name="publicationYear" class="form-control"
              value="<%= dataset.publicationYear %>" required>
          </div>
          <div class="form-group">
            <label class="form-label required" for="datasetSize">Dataset Size</label>
            <input type="number" id="datasetSize" name="datasetSize" class="form-control"
              value="<%= dataset.datasetSize %>" required>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="tags">Tags</label>
            <input type="text" id="tags" name="tags" class="form-control"
              value="<%= dataset.tags.join(', ') %>">
          </div>
          <div class="form-group">
            <label class="form-label" for="status">Status</label>
            <select id="status" name="status" class="form-control">
              <option value="active" <%= dataset.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="under_review" <%= dataset.status === 'under_review' ? 'selected' : '' %>>Under Review</option>
              <option value="archived" <%= dataset.status === 'archived' ? 'selected' : '' %>>Archived</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="card" style="margin-bottom: 20px;">
      <div class="card-body">
        <div class="form-section-title">📊 Distribution Data</div>

        <div class="form-section-title" style="font-size:0.9rem; border-bottom-style:dashed; color:var(--text-mid);">Age Groups</div>
        <div class="form-row-3">
          <div class="form-group">
            <label class="form-label" for="age18_30">18–30 (%)</label>
            <input type="number" id="age18_30" name="age18_30" class="form-control"
              value="<%= dataset.ageDistribution.age18_30 %>" min="0" max="100" step="0.1" data-percent>
          </div>
          <div class="form-group">
            <label class="form-label" for="age31_45">31–45 (%)</label>
            <input type="number" id="age31_45" name="age31_45" class="form-control"
              value="<%= dataset.ageDistribution.age31_45 %>" min="0" max="100" step="0.1" data-percent>
          </div>
          <div class="form-group">
            <label class="form-label" for="age46_85">46–85 (%)</label>
            <input type="number" id="age46_85" name="age46_85" class="form-control"
              value="<%= dataset.ageDistribution.age46_85 %>" min="0" max="100" step="0.1" data-percent>
          </div>
        </div>

        <div class="form-section-title" style="font-size:0.9rem; border-bottom-style:dashed; color:var(--text-mid); margin-top:8px;">Gender</div>
        <div class="form-row-3">
          <div class="form-group">
            <label class="form-label" for="genderMale">Male (%)</label>
            <input type="number" id="genderMale" name="genderMale" class="form-control"
              value="<%= dataset.genderDistribution.male %>" min="0" max="100" step="0.1" data-percent>
          </div>
          <div class="form-group">
            <label class="form-label" for="genderFemale">Female (%)</label>
            <input type="number" id="genderFemale" name="genderFemale" class="form-control"
              value="<%= dataset.genderDistribution.female %>" min="0" max="100" step="0.1" data-percent>
          </div>
          <div class="form-group">
            <label class="form-label" for="genderOther">Other (%)</label>
            <input type="number" id="genderOther" name="genderOther" class="form-control"
              value="<%= dataset.genderDistribution.other %>" min="0" max="100" step="0.1" data-percent>
          </div>
        </div>

        <div class="form-section-title" style="font-size:0.9rem; border-bottom-style:dashed; color:var(--text-mid); margin-top:8px;">Fitzpatrick Skin Tones</div>
        <div class="form-row-3">
          <% ['I','II','III','IV','V','VI'].forEach((t, i) => {
            const keys = ['typeI','typeII','typeIII','typeIV','typeV','typeVI'];
            const labels = ['Pale White','White','Light Brown','Brown','Dark Brown','Very Dark'];
            const fieldName = 'skinType' + t;
          %>
          <div class="form-group">
            <label class="form-label" for="<%= fieldName %>">
              <span class="skin-dot skin-<%= t %>" style="display:inline-block;vertical-align:middle;"></span>
              Type <%= t %> (%)
            </label>
            <input type="number" id="<%= fieldName %>" name="<%= fieldName %>" class="form-control"
              value="<%= dataset.skinToneDistribution[keys[i]] %>" min="0" max="100" step="0.1" data-percent>
          </div>
          <% }) %>
        </div>

        <div class="form-section-title" style="font-size:0.9rem; border-bottom-style:dashed; color:var(--text-mid); margin-top:8px;">Lighting</div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="lightBright">☀️ Bright (%)</label>
            <input type="number" id="lightBright" name="lightBright" class="form-control"
              value="<%= dataset.lightingCondition.bright %>" min="0" max="100" step="0.1" data-percent>
          </div>
          <div class="form-group">
            <label class="form-label" for="lightDark">🌑 Dark (%)</label>
            <input type="number" id="lightDark" name="lightDark" class="form-control"
              value="<%= dataset.lightingCondition.dark %>" min="0" max="100" step="0.1" data-percent>
          </div>
        </div>
      </div>
    </div>

    <div class="card" style="margin-bottom: 24px;">
      <div class="card-body">
        <div class="form-section-title">📎 Replace Files (optional)</div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="paperFile">New Research Paper PDF</label>
            <input type="file" id="paperFile" name="paperFile" class="form-control-file" accept=".pdf">
            <% if (dataset.paperFile) { %>
              <div class="form-hint">Current: <a href="<%= dataset.paperFile %>" target="_blank" style="color:var(--teal-dim);">View current paper</a></div>
            <% } %>
          </div>
          <div class="form-group">
            <label class="form-label" for="datasetFile">New Dataset File</label>
            <input type="file" id="datasetFile" name="datasetFile" class="form-control-file" accept=".zip,.csv,.json">
            <% if (dataset.datasetFile) { %>
              <div class="form-hint">Current file available for download</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div style="display:flex; gap:12px;">
      <button type="submit" class="btn btn-teal btn-lg">💾 Save Changes</button>
      <a href="/datasets/<%= dataset._id %>" class="btn btn-outline btn-lg">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/layout_end') %>
